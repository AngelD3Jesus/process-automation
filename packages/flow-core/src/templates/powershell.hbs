# Generated by Process Automation Script Generator

$ctx = @{}

function Read-File([string]$Path) {
  if (-not $Path.StartsWith("./data/")) { throw "Ruta no permitida: $Path" }
  return Get-Content -Raw -Path $Path
}

function Process-Text([string]$Text, [string]$Mode) {
  if ($Mode -eq "upper") { return $Text.ToUpper() }
  if ($Mode -eq "lower") { return $Text.ToLower() }
  if ($Mode -eq "trim")  { return $Text.Trim() }
  return $Text
}

function Send-Email([string]$To, [string]$Subject, [string]$Body) {
  Write-Host "[EMAIL MOCK]" $To $Subject ($Body.Substring(0, [Math]::Min(120, $Body.Length)))
}

{{#each steps}}
{{#if (eq op "trigger")}}
# Trigger
{{#if (eq op "readFile")}}
