{{/if}}
{{#if (eq op "processText")}}
$ctx.fileText = Process-Text ($ctx.fileText) {{json mode}}
{{/if}}
{{#if (eq op "sendEmail")}}
Send-Email {{json to}} {{json subject}} ([string]$ctx.fileText)
{{/if}}
{{#if (eq op "end")}}
Write-Host "[DONE]"
return $ctx
{{/if}}
{{/each}}